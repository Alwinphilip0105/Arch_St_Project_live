# ============================================================
# Arch Street Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ============================================================

# Google Sheets published CSV URL
# Get from: File → Share → Publish to web → CSV
REACT_APP_SHEET_CSV_URL=

# Auto-sync interval in milliseconds
# 86400000 = 24 hours
REACT_APP_SYNC_INTERVAL=86400000

# Debug logging
REACT_APP_DEBUG=false
