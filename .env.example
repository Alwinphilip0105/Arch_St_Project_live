# ============================================================
# Arch Street Burial Site Dashboard — Environment Variables
# Copy this file to .env and fill in your own values.
# Never commit .env to GitHub — only commit .env.example
# ============================================================

# Google Sheets published CSV URL
# Get from: File → Share → Publish to web → CSV
REACT_APP_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vQVoUKEKOtCsiyCE6M9k305Ka5vAeUoqBxmZMgwmfPFrVkkk8sZtq7pgC8mMY4_wfOQfyzCpIBnfPY8/pub?output=csv 

# Auto-sync interval in milliseconds (86400000 = 24 hours)
REACT_APP_SYNC_INTERVAL=86400000

# Authentication: Netlify Identity — enable in Netlify dashboard (Identity tab).

# Debug logging: true | false
REACT_APP_DEBUG=false

